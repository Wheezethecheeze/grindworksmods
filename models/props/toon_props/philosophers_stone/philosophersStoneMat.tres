[sub_resource type="Shader" id="Shader_tv42k"]
code = "// NOTE: Shader automatically converted from Godot Engine 4.5.stable's StandardMaterial3D.

shader_type spatial;
render_mode blend_mix, depth_prepass_alpha, cull_back, unshaded;

uniform sampler2D texture_albedo : source_color, filter_linear_mipmap, repeat_enable;

uniform vec3 uv1_scale;
uniform vec3 uv1_offset;

uniform sampler2D Matcap : source_color;

void vertex() {
	UV = UV * uv1_scale.xy + uv1_offset.xy;

	vec3 centerNormal = vec3(0.0, 0.0, 0.0);

    // Sum up normals of neighboring vertices
    for (int i = 0; i < 8; i++) {  // Consider 8 neighboring vertices (adjust as needed)
        centerNormal += NORMAL;  // Assuming NORMAL is the normal attribute passed to the shader
    }

    // Normalize the sum to get an average normal
    centerNormal = normalize(centerNormal);

    // Use centerNormal for further calculations or pass it to the fragment shader
    NORMAL = centerNormal;
}

void fragment() {
	vec3 vertex_vs = normalize(VERTEX);
	vec3 normal_vs = NORMAL;
	
	vec3 coord = cross(vertex_vs, normal_vs);
	vec2 uv_vs = vec2(coord.x, coord.y);
	uv_vs *= 0.5;
	uv_vs += 0.5;
	
	vec3 matcap = texture(Matcap, uv_vs).rgb;
	vec3 rough_tex = texture(texture_albedo, UV).rgb;
	float rough_contribute = 0.0;
	if (rough_tex.r < 0.5) {
		rough_contribute = 0.25;
	}
	
	ALBEDO = mix(matcap, rough_tex.rgb, rough_contribute);
	ALPHA = 0.95;
}
"

