red_chair_toon_phrases = Array[String](["No Cogs here, my friend. The coast is clear!", "If you're here for the sale on deck chairs, I just got the last one.", "Wait, don't move. You're keeping the sun outta my eyes.", "Jealous? Well, there's no room for you on here.", "Yoooo.", "Y'know, I actually know the Toon that painted that landscape.", "Zzz... HAH! I was faking it! You couldn't even tell."])
