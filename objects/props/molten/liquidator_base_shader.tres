code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform vec2 Melt_Speed;
uniform vec2 Melt_Scale;
uniform sampler2D tex_frg_21 : source_color;
uniform sampler2D tex_frg_31 : source_color;
uniform sampler2D tex_frg_11 : source_color;
uniform vec2 Noise_Speed;
uniform sampler2D tex_frg_13 : source_color;
uniform float Noise_Power;
uniform sampler2D tex_frg_2 : source_color;
uniform float Fresnel_Power = 1.5;
uniform sampler2D tex_frg_37;



void fragment() {
// Vector2Parameter:34
	vec2 n_out34p0 = Melt_Speed;


// Input:23
	float n_out23p0 = TIME;


// UVFunc:24
	vec2 n_out24p0 = vec2(n_out23p0) * n_out34p0 + UV;


// Vector2Parameter:35
	vec2 n_out35p0 = Melt_Scale;


// UVFunc:26
	vec2 n_in26p2 = vec2(0.00000, 0.00000);
	vec2 n_out26p0 = (n_out24p0 - n_in26p2) * n_out35p0 + n_in26p2;


// Texture2D:21
	vec4 n_out21p0 = texture(tex_frg_21, n_out26p0);


// Texture2D:31
	vec4 n_out31p0 = texture(tex_frg_31, UV);


// FloatOp:32
	float n_out32p0 = n_out21p0.x * n_out31p0.x;


// ColorConstant:28
	vec4 n_out28p0 = vec4(0.988235, 0.368627, 0.000000, 1.000000);


	vec3 n_out27p0;
// ColorOp:27
	{
		float base = vec3(n_out32p0).x;
		float blend = vec3(n_out28p0.xyz).x;
		if (base < 0.5) {
			n_out27p0.x = 2.0 * base * blend;
		} else {
			n_out27p0.x = 1.0 - 2.0 * (1.0 - blend) * (1.0 - base);
		}
	}
	{
		float base = vec3(n_out32p0).y;
		float blend = vec3(n_out28p0.xyz).y;
		if (base < 0.5) {
			n_out27p0.y = 2.0 * base * blend;
		} else {
			n_out27p0.y = 1.0 - 2.0 * (1.0 - blend) * (1.0 - base);
		}
	}
	{
		float base = vec3(n_out32p0).z;
		float blend = vec3(n_out28p0.xyz).z;
		if (base < 0.5) {
			n_out27p0.z = 2.0 * base * blend;
		} else {
			n_out27p0.z = 1.0 - 2.0 * (1.0 - blend) * (1.0 - base);
		}
	}


// Texture2D:11
	vec4 n_out11p0 = texture(tex_frg_11, UV);


// Vector2Parameter:33
	vec2 n_out33p0 = Noise_Speed;


// Input:15
	float n_out15p0 = TIME;


// UVFunc:14
	vec2 n_out14p0 = vec2(n_out15p0) * n_out33p0 + UV;


// Texture2D:13
	vec4 n_out13p0 = texture(tex_frg_13, n_out14p0);


// FloatParameter:19
	float n_out19p0 = Noise_Power;


// FloatOp:20
	float n_out20p0 = n_out13p0.x * n_out19p0;


// Input:16
	vec2 n_out16p0 = UV;


// VectorOp:18
	vec2 n_out18p0 = vec2(n_out20p0) + n_out16p0;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out18p0);


	vec3 n_out12p0;
// ColorOp:12
	{
		float base = vec3(n_out11p0.xyz).x;
		float blend = vec3(n_out2p0.xyz).x;
		if (base < 0.5) {
			n_out12p0.x = (base * (2.0 * blend));
		} else {
			n_out12p0.x = (1.0 - (1.0 - base) * (1.0 - 2.0 * (blend - 0.5)));
		}
	}
	{
		float base = vec3(n_out11p0.xyz).y;
		float blend = vec3(n_out2p0.xyz).y;
		if (base < 0.5) {
			n_out12p0.y = (base * (2.0 * blend));
		} else {
			n_out12p0.y = (1.0 - (1.0 - base) * (1.0 - 2.0 * (blend - 0.5)));
		}
	}
	{
		float base = vec3(n_out11p0.xyz).z;
		float blend = vec3(n_out2p0.xyz).z;
		if (base < 0.5) {
			n_out12p0.z = (base * (2.0 * blend));
		} else {
			n_out12p0.z = (1.0 - (1.0 - base) * (1.0 - 2.0 * (blend - 0.5)));
		}
	}


// ColorOp:22
	vec3 n_out22p0 = vec3(1.0) - (vec3(1.0) - n_out27p0) * (vec3(1.0) - n_out12p0);


// FloatParameter:4
	float n_out4p0 = Fresnel_Power;


// Fresnel:3
	float n_out3p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_out4p0);


// Texture2D:37
	vec4 n_out37p0 = texture(tex_frg_37, UV);


// FloatOp:36
	float n_out36p0 = n_out3p0 * n_out37p0.x;


// ColorConstant:7
	vec4 n_out7p0 = vec4(1.000000, 0.482353, 0.000000, 1.000000);


// ColorOp:10
	vec3 n_out10p0 = min(vec3(n_out36p0), vec3(n_out7p0.xyz));


// Output:0
	ALBEDO = n_out22p0;
	EMISSION = n_out10p0;


}
