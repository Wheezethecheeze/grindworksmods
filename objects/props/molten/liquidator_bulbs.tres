code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, depth_test_default, cull_disabled, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D Gradient : source_color;
uniform vec2 Noise_Speed;
uniform sampler2D tex_frg_10 : source_color;
uniform float Noise_Power;
uniform sampler2D tex_frg_2 : source_color;
uniform float Fresnel_Power = 5.0;



void fragment() {
	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(Gradient, UV);


// Vector2Parameter:17
	vec2 n_out17p0 = Noise_Speed;


// Input:12
	float n_out12p0 = TIME;


// UVFunc:11
	vec2 n_out11p0 = vec2(n_out12p0) * n_out17p0 + UV;


// Texture2D:10
	vec4 n_out10p0 = texture(tex_frg_10, n_out11p0);


// FloatParameter:13
	float n_out13p0 = Noise_Power;


// FloatOp:16
	float n_out16p0 = n_out10p0.x * n_out13p0;


// Input:14
	vec2 n_out14p0 = UV;


// VectorOp:15
	vec2 n_out15p0 = vec2(n_out16p0) + n_out14p0;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out15p0);


	vec3 n_out9p0;
// ColorOp:9
	{
		float base = vec3(n_out8p0.xyz).x;
		float blend = vec3(n_out2p0.xyz).x;
		if (base < 0.5) {
			n_out9p0.x = (base * (2.0 * blend));
		} else {
			n_out9p0.x = (1.0 - (1.0 - base) * (1.0 - 2.0 * (blend - 0.5)));
		}
	}
	{
		float base = vec3(n_out8p0.xyz).y;
		float blend = vec3(n_out2p0.xyz).y;
		if (base < 0.5) {
			n_out9p0.y = (base * (2.0 * blend));
		} else {
			n_out9p0.y = (1.0 - (1.0 - base) * (1.0 - 2.0 * (blend - 0.5)));
		}
	}
	{
		float base = vec3(n_out8p0.xyz).z;
		float blend = vec3(n_out2p0.xyz).z;
		if (base < 0.5) {
			n_out9p0.z = (base * (2.0 * blend));
		} else {
			n_out9p0.z = (1.0 - (1.0 - base) * (1.0 - 2.0 * (blend - 0.5)));
		}
	}


// FloatParameter:4
	float n_out4p0 = Fresnel_Power;


// Fresnel:3
	float n_out3p0 = pow(1.0 - clamp(dot(NORMAL, VIEW), 0.0, 1.0), n_out4p0);


// ColorConstant:6
	vec4 n_out6p0 = vec4(0.635461, 0.216770, 0.000000, 1.000000);


// ColorOp:5
	vec3 n_out5p0 = min(vec3(n_out3p0), vec3(n_out6p0.xyz));


// Output:0
	ALBEDO = n_out9p0;
	EMISSION = n_out5p0;


}
"
