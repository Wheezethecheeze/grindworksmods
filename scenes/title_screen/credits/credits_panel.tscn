[sub_resource type="GDScript" id="GDScript_hqko8"]
resource_name = "stripey_credit"
script/source = "extends HBoxContainer

## Stripey handed me a GIF, and said \"if that doesn't work I can send a png\"
## I took this as a challenge


func on_frame_changed() -> void:
	var frame: int = $Animation.frame
	$Icon.set_texture($Animation.sprite_frames.get_frame_texture('default', frame))
"

